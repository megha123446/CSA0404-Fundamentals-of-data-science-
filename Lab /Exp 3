import numpy as np
house_data = np.array([
    [1,3,1200,10,1,250000],
    [2,5,1800,8,2,450000],
    [3,4,1600,6,2,350000],
    [4,6,2100,5,2,550000],
    [5,5,1900,4,2,500000]
])
houses_more_than_4 = house_data[house_data[:,1] > 4]
average_price = np.mean(houses_more_than_4[:,5])
print("Average price of houses with more than 4 bedrooms:", round(average_price,2))
